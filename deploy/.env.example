# =============================================================================
# Hummingbot Edge Services — Environment Variables
# =============================================================================
# Copy this file as .env in the same directory as docker-compose.yml:
#   cp .env.example .env
#   nano .env
#
# Hostinger Docker Manager: paste these as env vars in the project settings.
# =============================================================================

# ─── Credentials (CHANGE BEFORE LIVE TRADING!) ──────────────────────────────
MQTT_USERNAME=admin
MQTT_PASSWORD=password
POSTGRES_USER=hbot
POSTGRES_PASSWORD=hummingbot-api
API_USERNAME=admin
API_PASSWORD=admin
CONFIG_PASSWORD=admin
GATEWAY_PASSPHRASE=admin

# ─── Telegram Alerts ────────────────────────────────────────────────────────
# Get token from @BotFather, chat ID from getUpdates API
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# ─── Trading Pair Defaults ──────────────────────────────────────────────────
SESSION_TARGET_PAIR=sol_usdc
SESSION_POLL_INTERVAL_SECONDS=60

REGIME_SYMBOL=SOLUSDT
REGIME_POLL_INTERVAL_SECONDS=300

FUNDING_SYMBOL=SOLUSDT
FUNDING_POLL_INTERVAL_SECONDS=300

CORR_TARGET_PAIR=sol_usdc
CORR_REFERENCE_PAIRS=ETHUSDT,BTCUSDT

ALPHA_MIN_SCORE=7
ALPHA_MIN_LIQUIDITY=50000
ALPHA_POLL_INTERVAL_SECONDS=900

ARB_MIN_ARB_PCT=0.5
ARB_MIN_LIQUIDITY=5000

FSCAN_HIGH_RATE_THRESHOLD=0.0003
FSCAN_MIN_ANNUALIZED_APR=30

NARR_MIN_VOLUME_SPIKE=2.0
NARR_MIN_VOLUME_24H=50000

REWARDS_MIN_EFFECTIVE_APR=20
REWARDS_MAX_RISK_SCORE=8

INV_TARGET_PAIR=sol_usdc
HEDGE_TARGET_PAIR=sol_usdc
HEDGE_DELTA_THRESHOLD=0.5
PNL_TARGET_PAIR=sol_usdc
PNL_POLL_INTERVAL_SECONDS=300

LAB_EVAL_INTERVAL_SECONDS=300

SWARM_MAX_ACTIVE_BOTS=50
SWARM_CAPITAL_PER_BOT=10
SWARM_AUTO_DEPLOY=false

CLMM_TARGET_PAIR=sol_usdc
CLMM_BASE_RANGE_PCT=2.0
CLMM_REBALANCE_THRESHOLD_PCT=70

WL_EVAL_INTERVAL_SECONDS=300
WL_MAX_ARB_TOKENS=40
WL_MAX_REWARDS_POOLS=20
WL_MAX_FUNDING_SYMBOLS=20

UNLOCK_PRE_UNLOCK_HOURS=24
UNLOCK_POST_UNLOCK_HOURS=48

MIG_NEW_POOL_MAX_AGE_MINUTES=60
